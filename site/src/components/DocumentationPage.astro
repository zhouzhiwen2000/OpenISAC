---
import readmeSections from "../generated/readme_sections.json";
import { navItems } from "../data/site.js";
import DocsLayout from "../layouts/DocsLayout.astro";

const { locale } = Astro.props;
const isZh = locale === "zh";
const lang = isZh ? "zh-CN" : "en";
const languageSwitch = isZh
  ? { href: "documentation.html", label: "En" }
  : { href: "documentation_zh.html", label: "中文" };

const sectionDescriptions = {
  zh: {
    硬件准备: "查看后端与前端所需硬件、节点连接方式，以及接口要求。",
    软件安装: "查看系统环境、依赖安装、构建流程，以及性能调优相关说明。",
    典型使用示例: "查看 BS、UE、前端可视化和网页配置控制台的典型运行方式。",
    参数说明: "查看 BS 与 UE 的参数表，以及对应的 YAML 配置解释。",
  },
  en: {
    "Hardware Setup": "See backend and frontend hardware requirements, node connections, and interface requirements.",
    "Software Installation": "See supported environments, dependency installation, build steps, and performance tuning notes.",
    "Typical Usage Example": "See typical BS, UE, frontend visualization, and web-console execution examples.",
    "Parameter Reference": "Read the BS and UE parameter tables together with their YAML meanings.",
  },
};

const localeData = isZh ? readmeSections.zh : readmeSections.en;
const topLevelOutline = localeData.outline.filter((item) => item.level === 2);
const cards = topLevelOutline.map((item) => ({
  tag: isZh ? "大标题" : "Top-level Section",
  title: item.title,
  body: sectionDescriptions[locale][item.title] ?? "",
  href: `#${item.id}`,
  cta: isZh ? `跳到${item.title}` : `Jump to ${item.title}`,
}));

const content = isZh
  ? {
      title: "文档中心 - OpenISAC",
      description: "OpenISAC 文档中心",
      heroTitle: "安装教程、运行示例与参数说明",
      heroLead: "汇总安装部署说明、典型运行示例，以及运行参数解释。",
      backLabel: "返回首页",
      navTitle: "文档导航",
      readmeHtml: localeData.html,
    }
  : {
      title: "Documentation - OpenISAC",
      description: "OpenISAC documentation",
      heroTitle: "Installation guide, run examples, and parameter reference",
      heroLead: "Installation steps, typical run examples, and runtime parameter explanations.",
      backLabel: "Back to Home",
      navTitle: "Documentation Map",
      readmeHtml: localeData.html,
    };
---

<DocsLayout
  title={content.title}
  description={content.description}
  lang={lang}
  pageKey="documentation"
  navItems={navItems[locale]}
  langSwitch={languageSwitch}
>
  <div class="page-hero">
    <div class="page-hero-panel">
      <span class="eyebrow">Documentation</span>
      <h1>{content.heroTitle}</h1>
      <p class="page-hero-lead">{content.heroLead}</p>
      <div class="link-row">
        <a href={isZh ? "index_zh.html" : "index.html"} class="button-secondary">{content.backLabel}</a>
      </div>
    </div>
  </div>

  <main>
    <section>
      <h2>{content.navTitle}</h2>
      <div class="resource-grid">
        {cards.map((card) => (
          <div class="resource-card">
            <span class="tag">{card.tag}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
            <a href={card.href} class="doc-link">{card.cta}</a>
          </div>
        ))}
      </div>
    </section>

    <section id="reference-manual">
      <div set:html={content.readmeHtml}></div>
    </section>
  </main>
</DocsLayout>
