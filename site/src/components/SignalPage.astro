---
import { navItems, signalContent } from "../data/site.js";
import DocsLayout from "../layouts/DocsLayout.astro";

const { locale } = Astro.props;
const content = signalContent[locale];
const layoutLang = locale === "zh" ? "zh-CN" : "en";
const languageSwitch = locale === "zh"
  ? { href: "signal_processing.html", label: "En" }
  : { href: "signal_processing_zh.html", label: "中文" };
const hero = locale === "zh"
  ? {
      title: "PHY 与感知信号处理",
      lead: "汇总 OpenISAC 使用的信号模型、单站感知处理流程、UE 接收流程，以及双站 OTA 同步的关键处理细节。",
      back: "返回首页",
      homeHref: "index_zh.html",
    }
  : {
      title: "PHY and sensing signal processing",
      lead: "Signal model, monostatic sensing pipeline, UE reception, and bistatic OTA synchronization details used by OpenISAC.",
      back: "Back to Home",
      homeHref: "index.html",
    };
---

<DocsLayout
  title={content.title}
  description={content.description}
  lang={layoutLang}
  pageKey="signal"
  navItems={navItems[locale]}
  langSwitch={languageSwitch}
  math={true}
>
  <div class="page-hero">
    <div class="page-hero-panel">
      <span class="eyebrow">Signal Processing</span>
      <h1>{hero.title}</h1>
      <p class="page-hero-lead">{hero.lead}</p>
      <div class="link-row">
        <a href={hero.homeHref} class="button-secondary">{hero.back}</a>
      </div>
    </div>
  </div>

  <main>
    {content.sections.map((section) => (
      <section id={section.id}>
        <h2>{section.title}</h2>
        <div set:html={section.html}></div>
      </section>
    ))}
  </main>
</DocsLayout>
