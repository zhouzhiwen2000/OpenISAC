---
const { navItems, pageKey, langSwitch, lang } = Astro.props;
---

<header>
  <nav>
    <a href={String(lang).startsWith("zh") ? "index_zh.html" : "index.html"} class="logo">
      <img src="images/logo.svg" alt="OpenISAC" />
    </a>
    <ul class="nav-links" aria-label={String(lang).startsWith("zh") ? "主导航" : "Main navigation"}>
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={{ active: item.key === pageKey }}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer noopener" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li><a href={langSwitch.href}>{langSwitch.label}</a></li>
    </ul>
  </nav>
</header>
