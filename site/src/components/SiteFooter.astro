---
import { footerAuthors } from "../data/site.js";

const { lang, year } = Astro.props;
const isZh = String(lang).startsWith("zh");
const authorsLabel = isZh ? "作者" : "Authors";
const authors = isZh
  ? [
      "周智文 (zhiwen_zhou@seu.edu.cn)",
      "张超越 (chaoyue_zhang@seu.edu.cn)",
      "徐晓莉 (xiaolixu@seu.edu.cn)",
      "曾勇 (yong_zeng@seu.edu.cn)",
    ]
  : footerAuthors.map((author) => `${author.name} (${author.email})`);
---

<footer class="site-footer">
  <div class="footer-panel">
    <p>Copyright &copy; {year}, Zhiwen Zhou. Released under the BSD 2-Clause License.</p>
    <p><strong>{authorsLabel}:</strong> {authors.join(", ")}</p>
  </div>
</footer>
